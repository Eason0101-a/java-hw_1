{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Java",
      "type": "shell",
      "command": "javac",
      "args": [
        "-d",
        "out",
        "src/Main.java"
      ],
      "group": "build",
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Run Java",
      "type": "shell",
      "command": "java",
      "args": [
        "-cp",
        "out",
        "Main"
      ],
      "group": "test",
      "dependsOn": "Build Java"
    }
  ]
}
